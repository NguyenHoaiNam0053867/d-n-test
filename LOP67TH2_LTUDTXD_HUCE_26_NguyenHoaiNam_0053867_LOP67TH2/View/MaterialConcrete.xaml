<Page x:Class="LOP67TH2_LTUDTXD_HUCE_26_NguyenHoaiNam_0053867_LOP67TH2.View.MaterialConcrete"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LOP67TH2_LTUDTXD_HUCE_26_NguyenHoaiNam_0053867_LOP67TH2.View"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MaterialConcrete">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width=" 300"/>

            <ColumnDefinition  Width="*"/>


        </Grid.ColumnDefinitions>
        <GroupBox Header="Các loại bê tông " >
            <DataGrid x:Name="dtg_Beamm" >
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tên Bê tông " Binding="{Binding Mark }"/>

                </DataGrid.Columns>
            </DataGrid>


        </GroupBox>
        <GroupBox Header=" Cường độ  "  Grid.Column="1">
            <DataGrid x:Name="dtg_Beam" >
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Cấp bền " Binding="{Binding Mark }"/>
                    <DataGridTextColumn Header="Cươngf độ chịu nén (Rb) " Binding="{Binding Mark }"/>
                    <DataGridTextColumn Header="Cươngf độ chịu kéo (Rbt) " Binding="{Binding Mark }"/>
                    
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

    </Grid>
</Page>
